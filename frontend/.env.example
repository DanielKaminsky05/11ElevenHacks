# URL of the TransitRL FastAPI backend, used server-side by app/api/chat.
# Local dev: the backend's default port. On the Spark, set to its LAN address,
# e.g. http://192.168.1.50:9000. If unreachable, the chat falls back to a local
# keyword planner so the UI still works.
BACKEND_URL=http://localhost:9000
