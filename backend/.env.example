# Copy to .env and adjust. All vars are prefixed TRANSITRL_.
# Defaults assume the backend runs ON the Spark, with the NIM on the same box.

TRANSITRL_API_HOST=0.0.0.0
TRANSITRL_API_PORT=9000

# Frontend origin(s) allowed by CORS. JSON list. The laptop's Next dev server:
TRANSITRL_ALLOWED_ORIGINS=["http://localhost:3000"]

# Nemotron NIM (OpenAI-compatible). localhost because backend is co-located on the Spark.
TRANSITRL_NIM_BASE_URL=http://localhost:8000/v1
TRANSITRL_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# True on the laptop (no model) → FakeNIMClient. Set False on the Spark.
TRANSITRL_NIM_OFFLINE=true

# Where the open-data layers live (rasterized into the city grid at startup).
TRANSITRL_DATA_DIR=../data
TRANSITRL_GRID_RESOLUTION=30
